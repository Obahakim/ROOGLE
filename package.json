{
  "name": "roogle",
  "version": "0.2.0",
  "description": "ROOGLE — a Unicity Sphere wallet dashboard. Connect your wallet, see real holdings, send and swap tokens.",
  "scripts": {
    "dev": "tsx watch adapters/iframe/web-entry.ts",
    "build:client": "node esbuild.config.mjs",
    "build:server": "tsc",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/adapters/iframe/web-entry.js",
    "test": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@unicitylabs/sphere-sdk": "^0.10.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}