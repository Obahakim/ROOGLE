# ROOGLE Environment Configuration
# Copy this file to .env and fill in real values

# === LLM / Model (used by the orchestrator) ===
# Grok API (preferred)
GROK_API_KEY=1821679154439577600-jbIisznG96llroFuQnevAfQlZPM92N
GROK_MODEL=grok-3   # optional override

# Legacy / alternative (kept for reference)
# LLM_PROVIDER=grok
# OPENAI_API_KEY=your_openai_key_here
# Or use other providers supported by your runtime

# === Unicity Sphere SDK  ===
SPHERE_NETWORK=testnet   # testnet | mainnet
SPHERE_DATA_DIR=./.roogle-sphere-data
SPHERE_AGENT_ID=roogle-main
# SPHERE_MNEMONIC= tower fuel trick clutch boost business symptom knock glass require eagle reject
# SPHERE_API_KEY=sk_ddc3cfcc001e4a28ac3fad7407f99590 ...# Optional oracle key for pricing (not required for basic agent discovery)
# SPHERE_ORACLE_API_KEY=sk_ddc3cfcc001e4a28ac3fad7407f99590 

# === Agent Behavior (safe defaults) ===
MAX_TOOL_STEPS=5
CONFIRM_BEFORE_VALUE_MOVEMENT=true
DEFAULT_LANGUAGE=en

# === Discovery Settings ===
DISCOVERY_ENABLED=true
MAX_SPECIALIST_AGENTS_TO_CONSIDER=3
